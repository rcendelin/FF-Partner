{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "System": "Warning"
      }
    }
  },
  "ApplicationInsights": {
    "ConnectionString": ""
  },
  "Bridge": {
    "ServiceBus": {
      "Namespace": ""
    },
    "ApiKey": {
      "HeaderName": "X-Api-Key"
    },
    "Polling": {
      "IntervalMinutes": 5
    }
  }
}
